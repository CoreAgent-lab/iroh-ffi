{
  "name": "@cc-remote/iroh",
  "author": "cc-remote",
  "description": "A toolkit for building distributed applications",
  "keywords": [
    "iroh",
    "distributed",
    "applications",
    "p2p",
    "peer-to-peer",
    "networking",
    "network",
    "protocol"
  ],
  "version": "1.0.0-rc.4",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">= 20.3.0"
  },
  "napi": {
    "binaryName": "iroh",
    "targets": [
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "armv7-unknown-linux-gnueabihf",
      "armv7-unknown-linux-musleabihf"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CoreAgent-lab/iroh-ffi.git"
  },
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "typedoc": "^0.27.6",
    "typescript": "~5.8.3"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --strip",
    "build:debug": "napi build --platform",
    "docs": "typedoc",
    "prepublishOnly": "napi pre-publish -t npm --no-gh-release",
    "test": "node --test test/*.mjs",
    "version": "napi version"
  },
  "packageManager": "yarn@1.22.22",
  "publishConfig": {
    "access": "public"
  }
}
